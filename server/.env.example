# ============================================================
# Elemental Earth — 管理后台环境变量配置
# ============================================================

# OpenAI API 密钥（必填，AI 内容生成功能需要）
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API 基础地址（可选，使用代理或兼容 API 时设置）
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型名称（可选，默认 gpt-4o）
# OPENAI_MODEL=gpt-4o

# 管理后台登录密码（必填，通过 /admin 页面管理数据时需要）
ADMIN_PASSWORD=your-admin-password

# 服务端口（可选，默认 3001）
# PORT=3001
